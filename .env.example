# Copy this file to `.env` and adjust. `.env` is gitignored — never commit real keys.

# Which LLM backend to use:
#   github    — GitHub Models (strong, free for students; default)
#   ollama    — local model via Ollama (offline, no key)
#   anthropic — Claude API (paid)
AGENTIC_REG_LLM_PROVIDER=github

# --- GitHub Models (default) ---
AGENTIC_REG_GITHUB_MODEL=openai/gpt-4o
# Token is optional for local `uv run ...`: if unset, the app falls back to your
# logged-in `gh` CLI token. Docker/hosted deploys should pass GITHUB_TOKEN
# explicitly because they do not have your host `gh auth` session.
# GITHUB_TOKEN=ghp_...

# --- Ollama (local) ---
AGENTIC_REG_OLLAMA_MODEL=llama3.1:8b
AGENTIC_REG_OLLAMA_HOST=http://localhost:11434

# --- Anthropic (Claude) — only when LLM_PROVIDER=anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
AGENTIC_REG_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Embeddings (local, free) ---
AGENTIC_REG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Domain ---
AGENTIC_REG_DOMAIN=gdpr

# --- Retrieval tuning ---
AGENTIC_REG_VECTOR_TOP_K=4
AGENTIC_REG_GRAPH_HOPS=2
# use_graph=false makes retrieval vector-only (the ablation baseline)
AGENTIC_REG_USE_GRAPH=true

# --- Agent orchestration ---
# single = Phase 1/2 retrieve->reason->answer agent
# team   = multi-agent supervisor + specialists + verification + self-correction
AGENTIC_REG_AGENT_MODE=team
AGENTIC_REG_MAX_SUBQUESTIONS=3
AGENTIC_REG_MAX_REVISIONS=1
AGENTIC_REG_MAX_AGENT_DEPTH=2
AGENTIC_REG_MAX_AGENT_TASKS=8
AGENTIC_REG_SYMBOLIC_CHECKS=true
# off = no graph-update review, propose = write reviewed JSONL, apply = apply accepted changes
AGENTIC_REG_GRAPH_UPDATE_MODE=propose
# Optional override; default is data/store/<domain>/graph_proposals.jsonl
# AGENTIC_REG_GRAPH_PROPOSALS_PATH=data/store/gdpr/graph_proposals.jsonl

# Hosted demos should set GITHUB_TOKEN as a deployment secret (for example in
# Hugging Face Spaces settings), not in the repository.
